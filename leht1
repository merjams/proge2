<!doctype html>
<html>
  <head>
    <title>Video</title>
	<script>
	  let player=null, c=null, g=null, g2=null;
	  function start(){
	   player=document.getElementById("v1");
	   c=document.getElementById("c1")
	   g=c.getContext("2d");
	   g2=document.getElementById("c2").getContext("2d");
	   span1=document.getElementById("s1");
	   navigator.mediaDevices.getUserMedia({video:true}).then((stream) => {
         player.srcObject = stream;
       });
	   setInterval(capture, 1000);
	  }
	  function capture(){
	     g.drawImage(player, 0, 0, c.width, c.height);
		 g.strokeRect(98, 98, 44, 44);
		 let d=g.getImageData(100, 100, 40, 40);
		 g2.putImageData(d, 0, 0);
		 s1.innerHTML=d.data.slice(0,8);
	  }
	</script>
  </head>
  <body onload="start()">
    <video id="v1" controls autoplay style="width: 45%"></video>
	<canvas id="c1" width="320" height="240" style="width: 45%"/></canvas><br />	 
	<canvas id="c2" width="40" height="40"/></canvas>	
    <span id="s1"></span>	
  </body>
</html>
